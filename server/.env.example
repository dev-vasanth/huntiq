PORT=5000
MONGODB_URI=mongodb://localhost:27017/lead-radar
JWT_SECRET=your_super_secret_jwt_key_change_this



# Reddit OAuth App (for user account connection — post comments & send DMs)
# 1. Go to https://www.reddit.com/prefs/apps
# 2. Click "create another app", choose "web app"
# 3. Set redirect URI to: http://localhost:3000/api/reddit/callback
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
SERVER_URL=http://localhost:3000

# Email (for daily digest - uses Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=LeadRadar <your_email@gmail.com>

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
